rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidSituation(data) {
      return data.keys().hasAll(['id', 'title', 'userId']) &&
             data.id is string &&
             data.title is string &&
             data.userId == request.auth.uid;
    }

    match /situations/{situationId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isSignedIn() && isValidSituation(request.resource.data);
      allow update: if isOwner(resource.data.userId) && 
                     isValidSituation(request.resource.data) &&
                     request.resource.data.userId == resource.data.userId;
      allow delete: if isOwner(resource.data.userId);
    }
  }
}
